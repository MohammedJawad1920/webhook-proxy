# Server
PORT=3000
NODE_ENV=development

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=100
RETRY_MAX_DELAY_MS=5000

# Concurrency Configuration
MAX_CONCURRENT_FORWARDS=10

# Timeout Configuration
FORWARD_TIMEOUT_MS=1000

# Cache Configuration
CACHE_MAX_SIZE=100
CACHE_TTL_MS=300000

# Logging
LOG_LEVEL=info
